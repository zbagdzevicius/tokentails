{
  "name": "tokentails",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:https": "next dev --webpack --experimental-https",
    "build": "next build",
    "ngrok": "ngrok http --domain=game-doe-poorly.ngrok-free.app http://192.168.68.104:3000",
    "start": "next start",
    "postbuild": "next-sitemap",
    "extrude:food": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/food-original.png --output ./public/base/food.png",
    "extrude:blocks": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/blocks-original.png --output ./public/base/blocks.png",
    "extrude:enemies": "tile-extruder --tileWidth 33 --tileHeight 33 --margin 0 --spacing 0 --input ./public/enemies/white-owlet.png --output ./public/enemies/white-owlet.png",
    "extrude:winter": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/new-blocks-winter.png --output ./public/base/winter.png",
    "extrude:spring": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/spring-original.png --output ./public/base/spring.png",
    "extrude:autumn": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/autumn-original.png --output ./public/base/autumn.png",
    "extrude:construct": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/construct-original.png --output ./public/base/construct.png",
    "extrude:candy": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/candy-original.png --output ./public/base/candy.png",
    "extrude:camp": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/camp-original.png --output ./public/base/camp.png",
    "extrude:summit": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/summit-original.png --output ./public/base/summit.png",
    "extrude:stocks": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/stocks-original.png --output ./public/base/stocks.png",
    "extrude:combined": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/combined-original.png --output ./public/base/combined.png",
    "extrude:sei": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/sei-original.png --output ./public/base/sei.png",
    "extrude:daemons": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/daemons-original.png --output ./public/base/daemons.png",
    "extrude:catwinter": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/cat-winter-original.png --output ./public/base/cat-winter.png",
    "extrude:valentine": "tile-extruder --tileWidth 32 --tileHeight 32 --margin 0 --spacing 0 --input ./public/base/valentine-original.png --output ./public/base/valentine.png",
    "build:prod": "env-cmd -f .env.production next build",
    "build:app": "env-cmd -f .env.app next build",
    "app:sync": "npx cap copy && npx cap sync",
    "app:android:open": "npx cap open android",
    "app:android:build": "npx cap build android",
    "app:android:run": "npx cap run android -l --external",
    "app:android": "npm run build:app && npm run app:sync && npm run app:android:open",
    "app:ios:open": "npx cap open ios",
    "app:ios:build": "npx cap build ios",
    "app:ios:ci": "npm run build:app && npm run app:sync",
    "app:ios:run": "npx cap run ios -l --external",
    "app:ios": "npm run app:ios:ci && npm run app:ios:open",
    "app:assets": "capacitor-assets generate --iconBackgroundColor '#fc8b6d' --iconBackgroundColorDark '#fc8b6d' --splashBackgroundColor '#fc8b6d' --splashBackgroundColorDark '#fc8b6d' --logoSplashScale 0.4",
    "test": "jest",
    "coverage:check": "jest --coverage --passWithNoTests",
    "coverage": "jest --coverage --coverageReporters=cobertura && mv coverage/cobertura-coverage.xml coverage.xml"
  },
